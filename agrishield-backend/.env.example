# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/agrishield

# Africa's Talking (sandbox credentials for hackathon demo)
AT_USERNAME=sandbox
AT_API_KEY=your_sandbox_api_key_here
AT_SHORTCODE=*384*123#
AT_SENDER_ID=AgriShield

# If true, SMS/USSD calls are logged to console instead of hitting Africa's Talking
# Use this if you don't have sandbox credentials yet during development/judging
MOCK_AFRICAS_TALKING=true

# Drought rule engine
RAINFALL_THRESHOLD_MM=20
DROUGHT_WINDOW_DAYS=30

# Weather polling (cron expression) - every 6 hours by default
WEATHER_POLL_CRON=0 */6 * * *
